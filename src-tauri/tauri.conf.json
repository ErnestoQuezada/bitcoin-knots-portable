{
    "productName": "bitcoin-portable",
    "version": "0.2.5",
    "identifier": "com.bitcoin-portable.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Bitcoin Node",
                "width": 800,
                "height": 640,
                "resizable": true,
                "fullscreen": false,
                "center": true,
                "transparent": true,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/icon.ico"
        ]
    }
}